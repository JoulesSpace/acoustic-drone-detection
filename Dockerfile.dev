# syntax=docker/dockerfile:1
#
# Toolchain image for the `dev` compose service. The slim official Rust image
# omits rustfmt/clippy, which are our correctness oracles, so add them once here
# instead of re-downloading them on every `docker compose run --rm dev`.

FROM rust:1.92-slim-bookworm
RUN rustup component add rustfmt clippy
# libasound2-dev: `drone-live` depends on cpal, which needs ALSA headers to
# build on Linux (the live audio backend). pkg-config locates it.
RUN apt-get update \
    && apt-get install -y --no-install-recommends libasound2-dev pkg-config \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /work
