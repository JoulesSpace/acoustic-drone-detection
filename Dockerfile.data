# syntax=docker/dockerfile:1
#
# Dataset-download image: HuggingFace `datasets` + `soundfile` for streaming the
# DADS drone-audio subset into ./data. Separate from the plot image to keep each
# Python tool's deps minimal.

FROM python:3.12-slim
RUN apt-get update \
    && apt-get install -y --no-install-recommends libsndfile1 \
    && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir datasets==3.2.0 soundfile==0.12.1
WORKDIR /work
ENTRYPOINT ["python", "scripts/download_dads.py"]
